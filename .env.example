# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=rag_database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
EMBED_MODEL=qwen3-embedding:0.6b

# ── API Security ───────────────────────────────────────────────────────────────
# 설정하면 /chat, /ingest 요청에 X-API-Key 헤더 필수. 비워두면 인증 없음(개발용).
API_KEY=change_me_api_key

# ── Ingest Security ────────────────────────────────────────────────────────────
# /ingest 엔드포인트가 허용하는 최상위 디렉토리 (기본: backend/data)
# INGEST_ALLOWED_BASE=/absolute/path/to/allowed/folder
