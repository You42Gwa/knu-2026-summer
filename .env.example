# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=rag_database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
EMBED_MODEL=bge-m3

# ── ChromaDB 컬렉션 ─────────────────────────────────────────────────────────────
COLLECTION_NAME=scholarship_rules

# ── API Security ───────────────────────────────────────────────────────────────
# 설정하면 /chat, /summary, /ingest 요청에 X-API-Key 헤더 필수. 비워두면 인증 없음(개발용).
API_KEY=change_me_api_key

# ── Ingest Security ────────────────────────────────────────────────────────────
# /ingest 엔드포인트가 허용하는 최상위 디렉토리 (기본: backend/data)
# INGEST_ALLOWED_BASE=/absolute/path/to/allowed/folder

# ── 기관정보 (명세서 자동 작성용) ────────────────────────────────────────────────
# /summary 엔드포인트 기관정보 섹션에 포함됨
ORG_CORP_NAME=기관명을_입력하세요
ORG_BUSINESS_NO=000-00-00000
ORG_REPRESENTATIVE=대표자명
ORG_DONATION_TYPE=민법상비영리법인
ORG_EMAIL=example@email.com
ORG_BUSINESS_YEAR=2024-12
ORG_PHONE=000-000-0000
ORG_DESIGNATED_DATE=0000-00-00
ORG_ADDRESS=주소를_입력하세요
