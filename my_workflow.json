    {
      "parameters": {
        "jsCode": "return $input.all()\n  .map(item => {\n    const doc = item.json;\n\n    const text = Object.values(doc)\n      .join(\" \")\n      .normalize(\"NFKC\");\n\n    //목적에서 금액추출(없는 파일은 시트에서 제외)\n    const match = text.match(/([0-9][0-9,]*)\\s*만원/);\n\n    if (!match) return null;\n\n    //summary에서 총액오류라 임시\n    const amount = Number(match[1].replace(/,/g, \"\")) * 10000;\n\n    //목적에서 금액 제거\n    const purpose = String(doc[\"목적\"] || \"\")\n      .normalize(\"NFKC\")\n      .replace(/[-–]?\\s*[0-9][0-9,]*\\s*만원/g, \"\")\n      .trim();\n\n    return {\n      json: {\n        ...doc,\n        목적: purpose,\n        총액: amount,\n      }\n    };\n  })\n  .filter(Boolean);"
      },
      "type": "n8n-nodes-base.code",
