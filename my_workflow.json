    {
      "parameters": {
        "code": {
          "execute": {
            "code": "const items = this.getInputData();\n\n// ===== 입력 연결 가져오기 =====\nlet model = await this.getInputConnectionData(\"ai_languageModel\", 0);\nlet sqlTool = await this.getInputConnectionData(\"ai_tool\", 0, 0);\nlet vectorTool = await this.getInputConnectionData(\"ai_tool\", 0, 1);\n\n// 배열로 들어오는 경우 첫 번째 값 사용\nif (Array.isArray(model)) model = model[0];\nif (Array.isArray(sqlTool)) sqlTool = sqlTool[0];\nif (Array.isArray(vectorTool)) vectorTool = vectorTool[0];\n\nconst output = [];\n\n// ===== LLM 라우팅 =====\nasync function llmRoute(question, model) {\n  const prompt = `\n너는 질문 라우터다.\n반드시 아래 둘 중 하나만 출력해라.\n\nsql\nvector\n\n판단 기준:\n- sql: 이름, 명단, 학과, 번호 등 정형 데이터 조회\n- vector: 문서, 파일, 장학금, 고지서, 확인서, 규정 등 문서 검색\n\n질문: ${question}\n`.trim();\n\n  try {\n    const res = await model.invoke(prompt);\n\n    const raw = Array.isArray(res?.content)\n      ? res.content.map(v => v.text || \"\").join(\" \").trim()\n      : String(res?.content || \"\").trim();\n\n    const normalized = raw.toLowerCase();\n\n    return {\n      llmRaw: raw,\n      route: normalized.includes(\"sql\") ? \"sql\" : \"vector\",\n    };\n  } catch (error) {\n    return {\n      llmRaw: `LLM routing failed: ${error.message}`,\n      route: \"vector\",\n    };\n  }\n}\n\n// ===== tool 결과 파싱 =====\nfunction parseToolResult(toolResult) {\n  let parsed = toolResult;\n\n  if (typeof toolResult === \"string\") {\n    try {\n      parsed = JSON.parse(toolResult);\n    } catch {\n      parsed = { raw: toolResult };\n    }\n  }\n\n  if (Array.isArray(parsed)) {\n    parsed = parsed[0] || {};\n  }\n\n  return parsed;\n}\n\n// ===== 메인 처리 =====\nfor (const item of items) {\n  const question =\n    item.json.question ||\n    item.json.text ||\n    item.json.message ||\n    item.json.user_question ||\n    \"\";\n\n  // 무조건 LLM으로 분기\n  const llmResult = await llmRoute(question, model);\n  const route = llmResult.route;\n  const llmRaw = llmResult.llmRaw;\n\n  //tool 호출\n  let toolResult;\n  if (route === \"sql\") {\n    toolResult = await sqlTool.invoke({ question });\n  } else {\n    toolResult = await vectorTool.invoke({ question });\n  }\n\n  const parsed = parseToolResult(toolResult);\n\n  // 👉 기존 출력 형태 유지\n  output.push({\n    json: {\n      ...item.json,\n      question,\n      route,\n      llm_raw: llmRaw,\n      tool_result: parsed,\n      document: parsed?.document || null,\n      full_text: parsed?.full_text || \"\",\n      message: parsed?.message || \"\",\n    },\n  });\n}\n\nreturn output;"
          }
        },
