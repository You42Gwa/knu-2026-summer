      "id": "db3fdb7d-532a-4462-a7dd-2d013ee2a10e",
      "name": "Run Chat For Headcount"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst DIR = '/files';\n\nconst exts = ['.hwp', '.pdf', '.xlsx'];\n\nfunction normalizeName(fileName) {\n  return String(fileName).normalize('NFKC');\n}\n\n//파일명에서 연도 추출\nfunction getYear(fileName) {\n  const name = normalizeName(fileName);\n\n  const match = name.match(/(?:19|20)\\d{2}/);\n  return match ? Number(match[0]) : null;\n}\n\n//파일명에서 총금액 존재 여부 확인\nfunction hasAmount(fileName) {\n  const name = normalizeName(fileName);\n  return /[0-9][0-9,]*\\s*만\\s*원/.test(name);\n}\n\nconst files = fs.readdirSync(DIR, { withFileTypes: true })\n  .filter(file => file.isFile())\n  .map(file => file.name)\n  .filter(fileName => !fileName.startsWith('.'))\n  .filter(fileName => exts.includes(path.extname(fileName).toLowerCase()))\n  //파일명에 총금액 정보가 없는 파일 제외 \n  .filter(fileName => hasAmount(fileName));\n\nreturn files.map(fileName => {\n  const filePath = path.join(DIR, fileName);\n  const stat = fs.statSync(filePath);\n\n  const normalizedFileName = normalizeName(fileName);\n\n  const fileYear = getYear(fileName);\n  const createdYear = stat.birthtime.getFullYear();\n\n  //파일명에서 연도 없으면 생성년도 사용\n  const year = fileYear || createdYear;\n\n  return {\n    json: {\n      fileName: normalizedFileName,\n      rawFileName: fileName,\n      year,\n      yearSource: fileYear ? 'fileName' : 'createdDate',\n      question: `${normalizedFileName} 이 파일의 총인원 알려줘`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        784
      ],
      "id": "fc9544d9-bd3d-4820-8596-53638b7809f5",
      "name": "Prepare Domestic Request"
    },
    {
      "parameters": {
        "jsCode": "const answer = $json.answer || \"\";\n\nconst fileName = String(\n  $json.rawFileName ||\n  $json.fileName ||\n  $('Loop Over Items').item.json.fileName ||\n  \"\"\n).normalize(\"NFKC\");\n\n// 답변에서 총인원 추출\nconst people = answer.match(/([0-9,]+)\\s*명/);\n\n// 파일명에서 총금액 추출\nconst amount = fileName.match(/([0-9][0-9,]*)\\s*만\\s*원/);\n\nconst totalPeople = people\n  ? people[1].replace(/,/g, \"\")\n  : \"\";\n\n// 만원 단위 금액 추출\nconst amountValue = amount\n  ? amount[1].replace(/,/g, \"\")\n  : \"\";\n\nconst totalAmount = amountValue\n  ? String(Number(amountValue) * 10000)\n  : \"\";\n\n// 파일명에서 번호, 확장자, 금액을 제거해 목적 생성\nconst purpose = fileName\n  .replace(/^\\d+\\.\\s*/, \"\")\n  .replace(/\\.(hwp|xlsx|pdf)$/i, \"\")\n  .replace(/\\s*-\\s*[0-9][0-9,]*\\s*만\\s*원\\s*$/i, \"\")\n  .trim();\n\nreturn [\n  {\n    json: {\n      purpose,\n      totalPeople,\n      totalAmount\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1648,
        800
      ],
      "id": "75a2f8f6-c184-4f93-bf32-2b0aaa9e32dc",
      "name": "Parse Domestic Response"
    },
